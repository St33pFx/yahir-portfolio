---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactPage from '../components/ContactPage';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact JozeDzn',
  url: 'https://jozedzn.com/contact',
  description: 'Contact page for JozeDzn, Creative Developer based in Mexico.',
  mainEntity: {
    '@type': 'Person',
    name: 'JozeDzn',
    email: 'hello@jozedzn.com',
    url: 'https://jozedzn.com',
    sameAs: ['https://linkedin.com/in/jozedzn', 'https://instagram.com/jozedzn'],
  },
};
---
<BaseLayout
  title="Contact — JozeDzn | Creative Developer"
  description="Get in touch with JozeDzn — Creative Developer based in Mexico. Available for motion graphics, 3D art, web development, and interactive experience projects. hello@jozedzn.com"
  canonicalPath="/contact"
  jsonLd={contactSchema}
>
  <ContactPage client:load />
</BaseLayout>
